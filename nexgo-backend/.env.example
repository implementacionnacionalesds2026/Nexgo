# Nexgo Backend — Variables de Entorno
# Copia este archivo como .env y llena los valores

# ================================
# SERVIDOR
# ================================
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:4200

# ================================
# BASE DE DATOS (PostgreSQL / Supabase)
# ================================
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nexgo_db
DB_SSL=false     # true en producción (Railway/Supabase)

# ================================
# JWT
# ================================
JWT_SECRET=nexgo_super_secret_jwt_key_cambia_esto_en_produccion
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ================================
# GOOGLE MAPS (opcional para cálculo de distancias en backend)
# ================================
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ================================
# LOGS
# ================================
LOG_LEVEL=info
